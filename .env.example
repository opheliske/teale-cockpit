# ─── Supabase — public keys (safe to expose to the browser) ──────────────────
# Used by the app to read/write data as the connected user. RLS does the
# filtering. Find these in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Admin only — used by scripts/create-user.ts ─────────────────────────────
# Bypasses Row Level Security. NEVER commit this, NEVER expose it to the
# frontend (no NEXT_PUBLIC_ prefix). Keep it only in your local .env.local.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
